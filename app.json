{
  "expo": {
    "name": "kokikos",
    "slug": "kokikos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "kokikos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo.png",
        "backgroundImage": "./assets/logo.png",
        "monochromeImage": "./assets/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.arisandi_satria.kokikos"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        },
      ],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": true,
          "hidden": true,
          "style": "light"
        }
      ],
      "expo-font",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
     "androidNavigationBar": {
      "visible": "sticky-immersive"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "092db04c-3726-4df2-b78e-22641e4ccb1e"
      }
    }
  }
}
